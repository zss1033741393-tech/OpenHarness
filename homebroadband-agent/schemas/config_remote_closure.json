{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "RemoteClosureConfig",
  "description": "远程闭环配置",
  "required": ["version", "user_id", "closure_config"],
  "properties": {
    "version": {"type": "string"},
    "user_id": {"type": "string"},
    "closure_config": {
      "type": "object",
      "properties": {
        "strategy": {"type": "string", "enum": ["aggressive", "balanced", "conservative"]},
        "auto_recovery": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "max_retries": {"type": "integer"},
            "retry_interval_seconds": {"type": "integer"}
          }
        },
        "audit": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "audit_interval_minutes": {"type": "integer"},
            "rollback_on_failure": {"type": "boolean"}
          }
        }
      }
    }
  }
}
