{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "SolutionPlan",
  "description": "家宽体验感知优化方案结构体",
  "required": ["version", "generated_at", "goal_spec", "plans"],
  "properties": {
    "version": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "goal_spec": {"$ref": "goal_spec.json"},
    "plans": {
      "type": "object",
      "properties": {
        "experience_perception": {"type": "object", "description": "CEI体验感知方案"},
        "fault_diagnosis": {"type": "object", "description": "故障诊断方案"},
        "remote_closure": {"type": "object", "description": "远程闭环方案"},
        "dynamic_optimization": {"type": "object", "description": "动态优化方案"},
        "manual_fallback": {"type": "object", "description": "人工兜底方案"}
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "generation_mode": {"type": "string"},
        "worker_count": {"type": "integer"},
        "total_time_ms": {"type": "number"}
      }
    }
  }
}
