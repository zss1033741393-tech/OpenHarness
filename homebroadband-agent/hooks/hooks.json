{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "matcher": "config_translate",
        "command": "python homebroadband-agent/scripts/validate_constraints.py $ARGUMENTS",
        "timeout_seconds": 30,
        "block_on_failure": true
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "matcher": "config_translate",
        "command": "echo '配置转义完成，输出已写入 configs/ 目录'",
        "timeout_seconds": 5,
        "block_on_failure": false
      }
    ]
  }
}
