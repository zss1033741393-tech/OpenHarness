{
  "pre_tool_use": [
    {
      "type": "command",
      "matcher": "config_translate",
      "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/validate_constraints.py $ARGUMENTS",
      "timeout": 30
    }
  ],
  "post_tool_use": [
    {
      "type": "command",
      "matcher": "config_translate",
      "command": "echo '配置转义完成，输出已写入 configs/ 目录'",
      "timeout": 5
    }
  ]
}
